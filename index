<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>5D寶可夢訓練中心</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --poke-red: #EE1515;
            --poke-yellow: #FFCB05;
            --poke-blue: #2A75BB;
            --center-bg: #E1F5FE; 
            --panel-bg: #FFFFFF;
            --text-dark: #2C3E50;
        }
        
        body {
            font-family: 'Nunito', 'Segoe UI', sans-serif;
            background-color: var(--center-bg);
            margin: 0; padding: 0; text-align: center; color: var(--text-dark);
            background-image: 
                linear-gradient(rgba(42, 117, 187, 0.1) 2px, transparent 2px),
                linear-gradient(90deg, rgba(42, 117, 187, 0.1) 2px, transparent 2px);
            background-size: 40px 40px;
        }
        
        .navbar {
            background-color: var(--poke-red); padding: 15px;
            box-shadow: 0 4px 15px rgba(238, 21, 21, 0.4);
            border-bottom: 6px solid #B71C1C; position: relative; z-index: 10;
        }
        .nav-btn {
            background-color: transparent; color: white; border: 3px solid white;
            padding: 10px 25px; margin: 0 10px; border-radius: 30px;
            cursor: pointer; font-size: 18px; font-weight: 900;
            transition: 0.2s; font-family: inherit;
        }
        .nav-btn.active, .nav-btn:hover {
            background-color: var(--poke-yellow); color: var(--text-dark);
            border-color: var(--poke-yellow); transform: scale(1.05);
        }

        .page { display: none; padding: 20px; max-width: 1400px; margin: 0 auto; }
        .page.active { display: block; }
        
        .training-center-layout { display: flex; gap: 30px; margin-top: 10px; align-items: flex-start; flex-wrap: wrap; }

        .master-column {
            flex: 1; min-width: 300px; max-width: 400px;
            background-color: rgba(255, 255, 255, 0.6); border: 5px solid var(--poke-blue);
            border-radius: 20px; position: sticky; top: 20px;
            height: calc(100vh - 120px); display: flex; flex-direction: column;
            justify-content: flex-end; overflow: hidden;
            box-shadow: inset 0 0 20px rgba(0,0,0,0.05), 0 8px 0 rgba(42, 117, 187, 0.2);
            background-image: url('teacher.png');
            background-size: 90%; background-repeat: no-repeat;
            background-position: center 20px; 
        }

        .dialogue-box {
            background: white; border: 4px solid var(--text-dark); border-radius: 15px;
            margin: 15px; padding: 15px; text-align: left; position: relative;
            box-shadow: 4px 4px 0 rgba(0,0,0,0.2); font-size: 18px; font-weight: 900;
            line-height: 1.5; color: var(--text-dark); z-index: 2; min-height: 80px;
        }
        .dialogue-box::after { content: '▼'; position: absolute; bottom: 5px; right: 10px; color: var(--poke-red); animation: bounce 1s infinite; }

        .students-column {
            flex: 3; background: rgba(255, 255, 255, 0.85); border-radius: 20px;
            padding: 25px; border: 5px solid #CFD8DC; box-shadow: 0 8px 0 rgba(0,0,0,0.05);
            min-height: 1200px; 
        }
        .students-column h2 { color: var(--poke-blue); font-size: 28px; margin-top: 0; border-bottom: 3px dashed #B0BEC5; padding-bottom: 15px; }

        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; }
        .card { background: var(--panel-bg); border-radius: 15px; padding: 20px 15px; box-shadow: 0 6px 0px rgba(0,0,0,0.1); border: 3px solid #E2E8F0; transition: all 0.2s; position: relative; }
        .card:hover { transform: translateY(-5px); box-shadow: 0 10px 0px rgba(0,0,0,0.15); border-color: var(--poke-yellow); }
        .avatar-img { width: 75px; height: 75px; background-color: #E2E8F0; border-radius: 50%; border: 4px solid var(--poke-blue); margin-bottom: 10px; }
        .trainer-name { color: var(--poke-blue); font-weight: 900; font-size: 1.3rem; margin-bottom: 10px;}
        
        .balls-container { height: 45px; margin: 10px 0 15px 0; display: flex; justify-content: center; align-items: center; gap: 6px; }
        .pokeball-wrap { width: 30px; height: 30px; position: relative; background: #fff; border-radius: 50%; border: 3px solid #000; box-shadow: inset -2px -2px 0 rgba(0,0,0,0.1), 0 3px 5px rgba(0,0,0,0.2); overflow: hidden; animation: bounceIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; flex-shrink: 0; }
        .pokeball-wrap:before { content: ''; position: absolute; background: var(--poke-red); width: 100%; height: 50%; top: 0; left: 0; border-bottom: 3px solid #000; }
        .pokeball-wrap:after { content: ''; position: absolute; background: #fff; width: 8px; height: 8px; border-radius: 50%; border: 3px solid #000; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 10; box-shadow: 0 0 0 2px #fff; }

        @keyframes bounceIn { 0% { transform: scale(0) translateY(-40px) rotate(-180deg); opacity: 0; } 60% { transform: scale(1.2) translateY(0) rotate(10deg); opacity: 1; } 100% { transform: scale(1) translateY(0) rotate(0); opacity: 1; } }
        @keyframes bounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(3px); } }
        
        .add-btn { background-color: var(--poke-blue); color: var(--poke-yellow); border: none; padding: 10px 15px; border-radius: 10px; cursor: pointer; font-weight: 900; font-size: 15px; font-family: inherit; box-shadow: 0 4px 0px #1A4D7C; transition: 0.1s; width: 100%; }
        .add-btn:active:not(:disabled) { transform: translateY(4px); box-shadow: 0 0px 0px #1A4D7C; }
        .add-btn:disabled { background-color: #95a5a6; color: #ecf0f1; box-shadow: 0 4px 0px #7f8c8d; cursor: not-allowed; }

        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); justify-content: center; align-items: center; z-index: 1000; }
        .modal-content { background: white; padding: 40px; border-radius: 30px; border: 8px solid var(--poke-yellow); text-align: center; animation: popUp 0.5s ease-out; max-width: 400px; }
        .gift-icon { font-size: 80px; margin-bottom: 20px; animation: tada 1s infinite; }
        @keyframes popUp { from { transform: scale(0.5); opacity: 0; } to { transform: scale(1); opacity: 1; } }
        @keyframes tada { 0% { transform: scale(1); } 10%, 20% { transform: scale(0.9) rotate(-3deg); } 30%, 50%, 70%, 90% { transform: scale(1.1) rotate(3deg); } 40%, 60%, 80% { transform: scale(1.1) rotate(-3deg); } 100% { transform: scale(1) rotate(0); } }

        .podium { display: flex; justify-content: center; align-items: flex-end; gap: 15px; margin-top: 80px; height: 350px; }
        .rank-box { display: flex; flex-direction: column; align-items: center; width: 140px; border-top-left-radius: 20px; border-top-right-radius: 20px; color: white; font-weight: 900; padding-top: 20px; box-shadow: 0 -4px 10px rgba(0,0,0,0.15); position: relative; }
        .rank-1 { background: linear-gradient(135deg, var(--poke-yellow), #F59E0B); height: 260px; border: 3px solid white; border-bottom: none;} 
        .rank-2 { background: linear-gradient(135deg, #9CA3AF, #6B7280); height: 190px; } 
        .rank-3 { background: linear-gradient(135deg, #B45309, #92400E); height: 140px; } 
        .rank-avatar { width: 80px; height: 80px; border-radius: 50%; background-color: white; border: 3px solid inherit; margin-bottom: 10px; margin-top: -50px; box-shadow: 0 4px 6px rgba(0,0,0,0.2); }
        .rank-score { font-size: 26px; margin-top: 10px; color: white; text-shadow: 1px 1px 2px rgba(0,0,0,0.5); }

        .error-msg { background: var(--poke-red); color: white; padding: 10px; border-radius: 10px; font-weight: bold; margin-bottom: 15px; display: none; }

        @media (max-width: 900px) {
            .training-center-layout { flex-direction: column; }
            .master-column { position: relative; top: 0; max-width: 100%; height: 400px; background-position: center 20px; }
            .grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 15px; }
            .navbar { display: flex; flex-direction: column; gap: 10px; }
            .nav-btn { margin: 0; width: 100%; }
            .podium { height: 250px; gap: 10px; margin-top: 50px; }
            .rank-box { width: 100px; }
            .rank-1 { height: 180px; }
            .rank-2 { height: 130px; }
            .rank-3 { height: 90px; }
            .rank-avatar { width: 60px; height: 60px; margin-top: -35px; }
            .rank-score { font-size: 20px; }
            .students-column { min-height: auto; }
        }
    </style>
</head>
<body>

    <div class="navbar">
        <button class="nav-btn active" onclick="switchTab('dashboard', this)">🏠 訓練中心大廳</button>
        <button class="nav-btn" onclick="switchTab('leaderboard', this)">🏆 聯盟殿堂排行</button>
    </div>

    <!-- 系統錯誤提示 (取代 alert) -->
    <div id="system-error" class="error-msg"></div>

    <div id="dashboard" class="page active">
        <div class="training-center-layout">
            <div class="master-column">
                <div class="dialogue-box">
                    <span style="color: var(--poke-blue);">館主大師：</span><br>
                    <span id="dialogue-text">「歡迎來到訓練中心！表現優異的訓練家，我會發送精靈球給你喔！」</span>
                </div>
            </div>

            <div class="students-column">
                <h2>今日訓練名單</h2>
                <div class="grid" id="student-grid"></div>
            </div>
        </div>
    </div>

    <div id="leaderboard" class="page">
        <h2 style="color: var(--poke-blue); font-size: 32px;">🌟 聯盟殿堂最強訓練家 🌟</h2>
        <div class="podium" id="podium-container"></div>
    </div>

    <div id="gift-modal" class="modal">
        <div class="modal-content">
            <div class="gift-icon">🎁</div>
            <h2 id="gift-message" style="color: var(--poke-red);">等級提升！</h2>
            <p style="font-size: 19px; font-weight: bold; color: #555;">請大師發放實體獎勵道具！</p>
            <button class="add-btn" onclick="closeModal()" style="margin-top: 25px; font-size: 18px; padding: 15px;">確認收服！重置精靈球</button>
        </div>
    </div>

    <!-- 讀取中畫面 -->
    <div id="loading-overlay" style="display: flex; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: var(--center-bg); justify-content: center; align-items: center; z-index: 2000; flex-direction: column;">
        <div class="pokeball-wrap" style="transform: scale(2); margin-bottom: 40px; animation: bounce 1s infinite;"></div>
        <h2 id="loading-text" style="color: var(--poke-blue);">連線至陳老師的雲端資料庫中... 📡</h2>
    </div>

    <script>
        // ==========================================
        // ⚠️ 老師請注意：把下面這行引號內的網址換成你的 GAS 部署網址 ⚠️
        // ==========================================
        const GAS_URL = "https://script.google.com/macros/s/AKfycbzoimXgptrXtpWS3yAoCZJePE14TASjJLDRrZhNM4IEKu1-PPVSYvCfdWgQvFn_bRUIbQ/exec"; 

        let students = [];
        const pokeballHtml = `<div class="pokeball-wrap"></div>`;

        // 音效設定 (更新為穩定可用的寶可夢音效連結)
        const sfxAdd = new Audio('https://www.myinstants.com/media/sounds/pokemon-a-button.mp3');
        const sfxLevelUp = new Audio('https://www.myinstants.com/media/sounds/pokemon-level-up.mp3');

        function switchTab(tabId, btnElement = null) {
            document.querySelectorAll('.page').forEach(page => page.classList.remove('active'));
            document.querySelectorAll('.nav-btn').forEach(btn => btn.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');
            if (btnElement) btnElement.classList.add('active');

            if(tabId === 'leaderboard') renderLeaderboard();
        }

        function showError(message) {
            const errorDiv = document.getElementById('system-error');
            errorDiv.innerText = message;
            errorDiv.style.display = 'block';
            setTimeout(() => { errorDiv.style.display = 'none'; }, 5000);
        }

        async function fetchStudents() {
            if(GAS_URL === "請將你的_GAS_網址_貼在這裡") {
                document.getElementById('loading-text').innerText = "⚠️ 尚未設定 GAS 網址，請依照教學修改 index.html 檔案！";
                document.getElementById('loading-text').style.color = "var(--poke-red)";
                return;
            }

            try {
                const response = await fetch(`${GAS_URL}?action=getStudents`);
                if(!response.ok) throw new Error("網路連線錯誤");
                
                students = await response.json();
                document.getElementById('loading-overlay').style.display = 'none';
                renderDashboard();
            } catch (error) {
                console.error("載入失敗:", error);
                document.getElementById('loading-text').innerText = "⚠️ 無法連線至資料庫，請檢查 GAS 部署權限是否設為「所有人」。";
                document.getElementById('loading-text').style.color = "var(--poke-red)";
            }
        }

        function renderDashboard() {
            const grid = document.getElementById('student-grid');
            grid.innerHTML = ''; 

            students.forEach(student => {
                const avatarUrl = `https://api.dicebear.com/9.x/pixel-art/svg?seed=${student.seed}`;
                let ballsHtml = '';
                for(let i=0; i < student.balls; i++) {
                    ballsHtml += `<div class="pokeball-wrap" style="animation-delay: ${i * 0.1}s"></div>`;
                }

                const card = document.createElement('div');
                card.className = 'card';
                card.innerHTML = `
                    <img src="${avatarUrl}" alt="Avatar" class="avatar-img">
                    <div class="trainer-name">${student.name}</div>
                    <div class="balls-container" id="balls-${student.id}">${ballsHtml}</div>
                    <button class="add-btn" id="btn-${student.id}" onclick="addBall(${student.id})">+ 1 精靈球</button>
                    <div style="font-size: 13px; color: #888; margin-top: 15px; font-weight: bold;">總收服數: <span id="total-${student.id}">${student.totalScore}</span></div>
                `;
                grid.appendChild(card);
            });
        }

        async function addBall(studentId) {
            const student = students.find(s => s.id === studentId);
            const btn = document.getElementById(`btn-${studentId}`);
            
            btn.disabled = true;
            btn.innerText = "儲存中 📡";

            try {
                // 使用 POST 將更新請求傳送給 GAS
                const response = await fetch(`${GAS_URL}?action=addBall&id=${studentId}`, { method: 'POST' });
                const result = await response.json();

                if (result.success) {
                    student.balls = result.balls;
                    student.totalScore = result.totalScore;

                    sfxAdd.currentTime = 0; sfxAdd.play().catch(e => {});

                    document.getElementById(`total-${studentId}`).innerText = student.totalScore;

                    const ballsContainer = document.getElementById(`balls-${studentId}`);
                    ballsContainer.innerHTML = ''; 
                    for(let i=0; i < student.balls; i++) {
                        const tempDiv = document.createElement('div');
                        tempDiv.innerHTML = `<div class="pokeball-wrap" style="animation-delay: ${i * 0.1}s"></div>`;
                        ballsContainer.appendChild(tempDiv.firstChild);
                    }

                    document.getElementById('dialogue-text').innerText = `「做得好，${student.name}！繼續保持這個氣勢！」`;

                    if (student.balls >= 5) {
                        setTimeout(async () => {
                            showGiftModal(student);
                            
                            // 呼叫重置 API
                            await fetch(`${GAS_URL}?action=resetBalls&id=${studentId}`, { method: 'POST' });
                            student.balls = 0; 
                            renderDashboard(); 
                            
                            setTimeout(() => {
                                 document.getElementById('dialogue-text').innerText = `「誰會是下一個拿到獎勵道具的訓練家呢？」`;
                            }, 3000);
                        }, 750); 
                    }
                }
            } catch (error) {
                console.error("更新失敗:", error);
                showError("⚠️ 連線伺服器失敗，請檢查網路狀態後再試！");
            } finally {
                btn.disabled = false;
                btn.innerText = "+ 1 精靈球";
            }
        }

        function showGiftModal(student) {
            sfxLevelUp.currentTime = 0; sfxLevelUp.play().catch(e => {});
            document.getElementById('gift-message').innerText = `✨ 太棒了！${student.name} 集滿 5 顆精靈球！ ✨`;
            document.getElementById('gift-modal').style.display = 'flex';
        }

        function closeModal() {
            document.getElementById('gift-modal').style.display = 'none';
        }

        function renderLeaderboard() {
            const podium = document.getElementById('podium-container');
            podium.innerHTML = ''; 

            const topStudents = [...students].sort((a, b) => b.totalScore - a.totalScore).slice(0, 3);
            const displayOrder = [topStudents[1], topStudents[0], topStudents[2]];

            displayOrder.forEach((student, index) => {
                if(!student) return; 
                const rankClass = index === 0 ? 'rank-2' : (index === 1 ? 'rank-1' : 'rank-3');
                const rankText = index === 0 ? '亞軍' : (index === 1 ? '👑 聯盟冠軍' : '季軍');
                const avatarUrl = `https://api.dicebear.com/9.x/pixel-art/svg?seed=${student.seed}`;

                const bar = document.createElement('div');
                bar.className = `rank-box ${rankClass}`;
                bar.innerHTML = `
                    <img src="${avatarUrl}" class="rank-avatar" alt="Avatar">
                    <div>${student.name}</div>
                    <div class="rank-score">${student.totalScore}</div>
                    <div style="margin-top: auto; padding-bottom: 20px;">${rankText}</div>
                `;
                podium.appendChild(bar);
            });
        }

        window.onload = () => {
            fetchStudents();
        };
    </script>
</body>
</html>
